# Copy this file to .env and fill in your credentials.
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
# Optional: Alternative name used by Google libraries
GOOGLE_API_KEY=...

# Better Auth Configuration
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-minimum-32-characters-long
# Development: http://localhost:3000
# Production: https://www.rowshni.xyz/
BETTER_AUTH_URL=http://localhost:3000

# Xero OAuth integration (optional)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Optional override. Defaults to ${BETTER_AUTH_URL}/api/integrations/xero/callback
XERO_REDIRECT_URI=http://localhost:3000/api/integrations/xero/callback
# Dev only: allow Xero OAuth/testing without auth + DB persistence (in-memory tokens)
XERO_DEV_NO_DB=false

# Resend email configuration (password resets)
RESEND_API_KEY=re_...
# Verified sender address in Resend
RESEND_FROM_EMAIL=support@rowshni.xyz

# Database Configuration (Neon PostgreSQL)
POSTGRES_URL=postgresql://user:password@host.neon.tech/database?sslmode=require
# Optional Claude Skills key (only needed for premium features)
ANTHROPIC_API_KEY=
# Orchestrator LLM mode: gemini (default, free), auto, openai, none
ORCHESTRATOR_LLM_MODE=gemini
# Optional explicit model choices
OPENAI_SUPERVISOR_MODEL=gpt-4o-mini
OPENAI_REVIEWER_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash  # Use 2.5-flash for higher quota (1500 requests/day free tier)
# Reconciliation controls
MATERIALITY_THRESHOLD=50

# S3 Drop Zone (optional automated ingest)
AWS_DROP_ZONE_BUCKET=acctrecon-drops
AWS_DROP_ZONE_REGION=us-east-1
AWS_DROP_ZONE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/acctrecon-drop-events
INGEST_INTERNAL_SECRET=replace-with-random-32-char-secret
INGEST_INTERNAL_URL=http://localhost:3100/api/ingest/s3-drop
INGEST_CONFLICT_MODE=overwrite
INGEST_ERROR_WEBHOOK_URL=
DROP_ZONE_ADMIN_EMAILS=admin@example.com
